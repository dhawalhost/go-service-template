# Server
APP_SERVER_ADDR=:8080
APP_SERVER_READ_TIMEOUT=30s
APP_SERVER_WRITE_TIMEOUT=30s
APP_SERVER_IDLE_TIMEOUT=120s
APP_SERVER_SHUTDOWN_TIMEOUT=30s

# Database
APP_DATABASE_DSN=postgres://pguser:password@localhost:5432/service_db?sslmode=disable
APP_DATABASE_MAX_OPEN_CONNS=25
APP_DATABASE_MAX_IDLE_CONNS=5
APP_DATABASE_CONN_MAX_LIFETIME=5m
APP_DATABASE_MIGRATIONS_PATH=./migrations

# Redis
APP_REDIS_ADDR=localhost:6379
APP_REDIS_PASSWORD=
APP_REDIS_DB=0

# JWT
APP_JWT_SECRET=your-super-secret-jwt-key-change-in-production
APP_JWT_EXPIRY=24h
APP_JWT_ISSUER=go-service-template

# Logging
APP_LOG_LEVEL=info
APP_LOG_DEVELOPMENT=false

# Telemetry
APP_TELEMETRY_ENABLED=false
APP_TELEMETRY_OTLP_ENDPOINT=http://localhost:4318
APP_TELEMETRY_SERVICE_NAME=go-service-template

# CORS
# Comma-separated list of allowed origins. Leave empty to restrict all CORS requests.
# Examples:
#   APP_CORS_ALLOWED_ORIGINS=http://localhost:3000,https://example.com
#   APP_CORS_ALLOWED_ORIGINS=  (empty = no CORS)
APP_CORS_ALLOWED_ORIGINS=http://localhost:3000

# Tenancy
# Leave disabled for single-tenant services. Enable to scope requests/data by X-Tenant-ID.
APP_TENANCY_ENABLED=false
APP_TENANCY_DEFAULT_TENANT_ID=default
